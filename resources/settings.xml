<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings>
    <category label="Indexer">
        <setting type="lsep" label="General Preferences" />
        <setting id="indexer_title_language" type="labelenum" label="Preferred Title Language" values="English|Romaji" default="English" />
        <setting id="enable_filler" type="bool" label="Enable Filler tagging (animefillerlist.com)" default="true" />

        <setting type="lsep" label="Database Cache" />
        <setting id="db_auto_update" type="bool" label="Automatically update local mapping database" default="true" />
        <setting id="db_update_interval" type="number" label="Database check interval (days)" default="7" enable="eq(-1,true)" />

        <setting type="lsep" label="Providers" />
        <setting id="provider_anizip" type="bool" label="Enable AniZip (Preferred for TVDB Mappings)" default="true" />
        <setting id="provider_jikan" type="bool" label="Enable Jikan (MyAnimeList)" default="true" />
        <setting id="provider_kitsu" type="bool" label="Enable Kitsu" default="true" />
        <setting id="provider_simkl" type="bool" label="Enable Simkl" default="true" />
        <setting id="provider_tvdb" type="bool" label="Enable TVDB (Fallback)" default="true" />
    </category>

    <category label="Renamer">
        <setting id="renamer_title_language" type="labelenum" label="Preferred Title Language" values="English|Romaji" default="English" />
        <setting type="lsep" label="Directory Formatting" />
        <setting id="renamer_folder_format" type="labelenum" label="Show Directory Format" values="Do not rename|Show Name|Show Name (Year)" default="Do not rename" />
        <setting id="renamer_season_format" type="labelenum" label="Season Sub-Directory Format" values="Flat (No Season Folders)|Season 1|Season 01" default="Flat (No Season Folders)" />
        <setting type="lsep" label="File Formatting" />
        <setting id="renamer_episode_format" type="labelenum" label="Episode Filename Format" values="Show Name S01E01 - Title|Show Name S01E01|S01E01 - Title|S01E01" default="Show Name S01E01 - Title" />
    </category>

    <category label="Metadata">
        <setting type="lsep" label="Ratings Configuration" />
        <setting id="rating_source" type="labelenum" label="Primary Rating Source" values="AniList|MyAnimeList|TMDb|Simkl" default="AniList" />
        <setting id="enable_anilist_rating" type="bool" label="Show AniList Rating" default="true" />
        <setting id="enable_mal_rating" type="bool" label="Show MyAnimeList (MAL) Rating" default="true" />
        <setting id="enable_tmdb_rating" type="bool" label="Show TMDb Rating" default="true" />
        <setting id="enable_simkl_rating" type="bool" label="Show Simkl Rating" default="true" />

        <setting type="lsep" label="Preferred Content Sources" />
        <setting id="plot_source" type="labelenum" label="Preferred Plot Source" values="AniList|TMDb" default="AniList" />
        <setting id="release_date_source" type="labelenum" label="Preferred Release Date Source" values="AniList|TMDb" default="AniList" />

        <setting type="lsep" label="Extended Details" />
        <setting id="fetch_trailers" type="bool" label="Fetch Trailers (YouTube)" default="true" />
        <setting id="fetch_cast" type="bool" label="Fetch Cast (Main Characters)" default="true" />
    </category>

    <category label="Fan Art">
        <setting id="enable_posters" type="bool" label="Enable Posters" default="true" />
        <setting id="enable_banners" type="bool" label="Enable Banners" default="true" />
        <setting id="enable_fanart" type="bool" label="Enable Fanart (Backgrounds)" default="true" />
        
        <setting type="lsep" label="Premium Artwork (Fanart.tv)" />
        <setting id="enable_fanart_tv" type="bool" label="Enable Fanart.tv" default="true" />
        <setting id="enable_clearlogos" type="bool" label="Enable Clearlogos" default="true" />
        <setting id="enable_clearart" type="bool" label="Enable Clearart" default="true" />
    </category>

    <category label="Accounts">
        <setting id="fanart_tv_api_key" type="text" label="Fanart.tv Client Key (Get at fanart.tv)" default="62fd37f8f94cb4c1f6de720a463ce8c9" />
        <setting id="simkl_api_key" type="text" label="Simkl Client ID (Get at https://simkl.com/apps)" default="4d63b27b3fa6972e7370ce15119dc9469e71ecfc647037f3747fccb2ef10f92d" />
        <setting id="tvdb_api_key" type="text" label="TVDB API Key (Get at https://thetvdb.com/api-information)" default="a832f059-e9eb-4a1b-bd5b-56af7b5ce1bf" />
        <setting id="tmdb_api_key" type="text" label="TMDb API Key (Get at https://www.themoviedb.org/settings/api)" default="af3a53eb387d57fc935e9128468b1899" />
    </category>

    <category label="Logging">
        <setting id="debug_level" type="labelenum" label="Log Level" values="ERROR|WARNING|INFO|DEBUG" default="INFO" />
        <setting id="custom_log_path" type="folder" label="Custom Log Directory (Optional)" default="" />
    </category>

    <category label="Advanced">
        <setting type="lsep" label="Configuration Management" />
        <setting id="backup_settings" type="action" label="Backup Addon Settings" action="RunScript(metadata.anime.otaku.python, ?action=backup_settings)" />
        <setting id="restore_settings" type="action" label="Restore Addon Settings" action="RunScript(metadata.anime.otaku.python, ?action=restore_settings)" />

        <setting type="lsep" label="Experimental" />
        <setting id="experimental_fast_match" type="bool" label="Enable Fast Matching (Experimental)" default="false" />
    </category>
</settings>
